# =============================================================
# Open Slap! — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# Restart the backend after any change.
# Never commit .env to version control.
# =============================================================


# -------------------------------------------------------------
# AUTHENTICATION
# -------------------------------------------------------------
# Secret key for JWT signing. Generate a random 32+ char string.
# If not set, a random value is used (tokens invalidate on restart).
# JWT_SECRET=replace_with_long_random_string


# -------------------------------------------------------------
# LLM PROVIDERS
# At least one provider must be configured.
# -------------------------------------------------------------

# Gemini (free tier at aistudio.google.com)
# GEMINI_API_KEYS=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Groq (free, fast — console.groq.com)
# GROQ_API_KEYS=your_groq_key_here
# GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI or compatible (OpenRouter, LM Studio, etc.)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Ollama — fully local, no internet required
# Install: https://ollama.com/download  |  then: ollama pull llama3.2
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Provider fallback order (first available wins)
PROVIDER_ORDER=gemini,groq,ollama,openai


# -------------------------------------------------------------
# SERVER
# -------------------------------------------------------------
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=false


# -------------------------------------------------------------
# OPEN SLAP! FEATURE FLAGS
# All default to safe/on values. Set to 0 to disable.
# -------------------------------------------------------------

# Answer Cache (CAC) — cache LLM responses for identical questions
# OPENSLAP_CAC=1
# OPENSLAP_CAC_MAX_AGE_HOURS=24

# RAG — retrieve relevant memories from SQLite before each LLM call
# OPENSLAP_RAG_SQLITE=1

# Memory write — save new facts from conversations to memory
# OPENSLAP_MEMORY_WRITE=1

# Memory redaction — strip PII/secrets before persisting to SQLite
# SLAP_MEMORY_REDACTION_ENABLED=1

# System profile — attach OS/environment context to LLM calls
# OPENSLAP_SYSTEM_PROFILE=1
# OPENSLAP_ATTACH_SYSTEM_PROFILE=1
# OPENSLAP_SYSTEM_PROFILE_MAX_CHARS=24000

# Web retrieval — keyword-triggered DuckDuckGo search (no key needed)
# Note: skills with web_search=true bypass this flag automatically.
# OPENSLAP_WEB_RETRIEVAL=1
# OPENSLAP_WEB_RETRIEVAL_TIMEOUT_S=6

# OS command execution — allow the agent to run shell commands
# OPENSLAP_OS_COMMANDS=1
# OPENSLAP_OS_COMMAND_TIMEOUT_S=12
# OPENSLAP_OS_COMMAND_MAX_OUTPUT_CHARS=12000
# OPENSLAP_OS_COMMAND_ALLOWED_ROOTS=


# -------------------------------------------------------------
# FRICTION REPORTING (security event logging to GitHub)
# -------------------------------------------------------------
# SLAP_FRICTION_MODE=auto        # auto | manual | off
# SLAP_FRICTION_SESSION_SALT=replace_with_random_salt
# SLAP_FRICTION_GITHUB_TOKEN=    # GitHub PAT with issues:write scope
# SLAP_FRICTION_GITHUB_REPO=owner/repo
