# 🔐 CONFIGURAÇÕES - AGÊNTICO v1.0
# Copie este arquivo para .env e preencha com seus dados

# --- AUTENTICAÇÃO ---
# Chave secreta para JWT (gere um valor aleatório)
JWT_SECRET=gere_uma_chave_secreta_aleatoria_aqui_com_pelo_menos_32_caracteres

# --- LLM PROVIDERS ---

# OBRIGATÓRIO para funcionar sem Ollama:
# Gemini API (gratuito em aistudio.google.com)
GEMINI_API_KEYS=sua_chave_gemini_aqui

# OPCIONAL mas recomendado (fallback rápido):
# Groq API (gratuito em console.groq.com)
GROQ_API_KEYS=sua_chave_groq_aqui

# OPCIONAL para uso 100% local (zero internet):
# Ollama local
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# OPCIONAL - outros providers compatíveis com OpenAI:
# OpenAI ou compatíveis (OpenRouter, LM Studio, etc.)
OPENAI_API_KEY=sk-sua_chave_openai_aqui
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- ORDEM DE FALLBACK ---
# Muda a prioridade dos providers (se um falhar, tenta o próximo)
PROVIDER_ORDER=gemini,groq,ollama,openai

# --- CONFIGURAÇÕES DO SISTEMA ---
# Ambiente (development/production)
ENVIRONMENT=development

# Porta do backend
BACKEND_PORT=8000

# Porta do frontend
FRONTEND_PORT=3000

# Debug mode
DEBUG=true

# --- BANCO DE DADOS ---
# Caminho para o banco SQLite (relativo ao backend)
DATABASE_PATH=data/auth.db

# --- SEGURANÇA ---
# Tempo de expiração do token (em minutos)
TOKEN_EXPIRE_MINUTES=10080

# CORS origins (separado por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LOGGING ---
# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=logs/agentic.log

SLAP_FRICTION_MODE=auto
SLAP_FRICTION_SESSION_SALT=troque_por_um_salt_aleatorio
SLAP_FRICTION_GITHUB_TOKEN=
SLAP_FRICTION_GITHUB_REPO=pemartins1970/slap-ecosystem
