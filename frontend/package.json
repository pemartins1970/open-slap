{
  "name": "agentic-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite_auth.config.js",
    "build": "vite build --config vite_auth.config.js",
    "preview": "vite preview --config vite_auth.config.js",
    "build:prod": "vite build --config vite_auth.config.js --mode production",
    "serve": "vite preview --config vite_auth.config.js --port 3000",
    "postinstall": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
