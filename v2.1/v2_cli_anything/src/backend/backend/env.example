# ============================================================
# AGÊNTICO - Configuração de Providers LLM
# ------------------------------------------------------------
# INSTRUÇÕES:
#   1. Copie este arquivo para: agentic/backend/.env
#   2. Preencha apenas os providers que quiser ativar
#   3. Reinicie o backend após qualquer alteração
#
# Providers não configurados são ignorados automaticamente.
# ============================================================


# ------------------------------------------------------------
# GEMINI (Google)
# Obter chave: https://aistudio.google.com/app/apikey
# Plano gratuito disponível
# ------------------------------------------------------------
# GEMINI_API_KEYS=sua_chave_gemini_aqui
# GEMINI_MODEL=gemini-1.5-flash


# ------------------------------------------------------------
# GROQ (gratuito, rápido)
# Obter chave: https://console.groq.com/keys
# ------------------------------------------------------------
# GROQ_API_KEYS=sua_chave_groq_aqui
# GROQ_MODEL=llama-3.1-70b-versatile


# ------------------------------------------------------------
# OPENAI
# Obter chave: https://platform.openai.com/api-keys
# ------------------------------------------------------------
# OPENAI_API_KEY=sua_chave_aqui
# OPENAI_MODEL=gpt-4o-mini


# ------------------------------------------------------------
# OLLAMA (local, sem custo, sem internet)
# Instalar: https://ollama.com/download
# Após instalar: ollama pull llama3.2
# Iniciar antes do backend: ollama serve
# ------------------------------------------------------------
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2


# ------------------------------------------------------------
# ORDEM DE FALLBACK (opcional)
# Define qual provider tenta primeiro, segundo, etc.
# ------------------------------------------------------------
# PROVIDER_ORDER=gemini,groq,ollama,openai


# ------------------------------------------------------------
# JWT (gerado automaticamente se não definido)
# Defina um valor fixo para tokens sobreviverem ao restart
# ------------------------------------------------------------
# JWT_SECRET=troque_por_uma_string_longa_e_aleatoria

SLAP_FRICTION_MODE=auto
SLAP_FRICTION_SESSION_SALT=troque_por_um_salt_aleatorio
SLAP_FRICTION_GITHUB_TOKEN=
SLAP_FRICTION_GITHUB_REPO=pemartins1970/slap-ecosystem
